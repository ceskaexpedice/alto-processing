# API keys for LLM agents
OPENAI_API_KEY=your-openai-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here
CERIT_API_KEY=your-cerit-api-key-here

# Authentication token for Alto Web
ALTO_WEB_AUTH_TOKEN=auth-token-here
ALTO_WEB_AUTH_COOKIE_SECURE=false

# FastAPI settings
ALTO_WEB_ENVIRONMENT=production

# Optional overrides
ALTO_WEB_APP_NAME=Alto Processing Web
